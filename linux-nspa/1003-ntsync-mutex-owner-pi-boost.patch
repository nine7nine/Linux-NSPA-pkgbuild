+/*
+ * NSPA: Drop any PI boost on a mutex and release the owner_task reference.
+ * Called when a mutex is fully released or destroyed.
+ */
+static void ntsync_pi_drop(struct ntsync_obj *obj)
+{
+	struct ntsync_device *dev = obj->dev;
+	struct ntsync_pi_owner *po;
+
+	if (!obj->u.mutex.owner_task)
+		return;
+
+	if (obj->u.mutex.pi_boosted) {
+		raw_spin_lock(&dev->boost_lock);
+		po = find_pi_owner(dev, obj->u.mutex.owner_task);
+		if (po) {
+			po->boost_count--;
+			if (po->boost_count <= 0) {
+				sched_setattr_nocheck(obj->u.mutex.owner_task,
+						      &po->orig_attr);
+				list_del(&po->node);
+				kfree(po);
+			}
+		}
+		raw_spin_unlock(&dev->boost_lock);
+		obj->u.mutex.pi_boosted = false;
+	}
+	put_task_struct(obj->u.mutex.owner_task);
+	obj->u.mutex.owner_task = NULL;
+}
+
+/*
+ * NSPA: Set a new owner_task for a mutex (with PI recalculation).
+ */
+static void ntsync_pi_set_owner(struct ntsync_obj *obj,
+				struct task_struct *new_owner)
+{
+	if (new_owner) {
+		get_task_struct(new_owner);
+		obj->u.mutex.owner_task = new_owner;
+		ntsync_pi_recalc(obj);
+	}
+}
