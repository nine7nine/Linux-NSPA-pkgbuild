+/*
+ * NSPA: Per-task PI boost tracking.
+ *
+ * When multiple ntsync mutexes boost the same owner task, we must save
+ * the original scheduling attributes exactly once (first boost) and
+ * restore only when ALL boosts are removed.  This structure is allocated
+ * per boosted owner and tracked on the device's boosted_owners list.
+ */
+struct ntsync_pi_owner {
+	struct list_head node;
+	struct task_struct *task;
+	struct sched_attr orig_attr;
+	int orig_normal_prio;	/* task->normal_prio before first boost */
+	int boost_count;	/* number of mutex objects boosting this task */
+};
