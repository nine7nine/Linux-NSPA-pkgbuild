+/*
+ * NSPA: Find the per-task PI tracking entry for a given owner.
+ * Must be called with dev->boost_lock held.
+ */
+static struct ntsync_pi_owner *find_pi_owner(struct ntsync_device *dev,
+					     struct task_struct *task)
+{
+	struct ntsync_pi_owner *po;
+
+	list_for_each_entry(po, &dev->boosted_owners, node) {
+		if (po->task == task)
+			return po;
+	}
+	return NULL;
+}
+
+/*
+ * NSPA: Recalculate PI boost for a mutex owner based on current waiters.
+ *
+ * Scans BOTH any_waiters and all_waiters (covering wait-any and wait-all)
+ * to find the highest-priority waiter.  Compares against the owner's
+ * ORIGINAL (pre-boost) priority via the per-task pi_owner tracking,
+ * avoiding the stale-normal_prio bug where sched_setattr_nocheck changes
+ * normal_prio after boost.
+ *
+ * Multi-object safety: when a task holds multiple mutexes being boosted,
+ * per-task boost_count ensures the original scheduling is saved once and
+ * restored only when ALL boosts are removed.  Between removal of the first
+ * and last boost, the task is conservatively over-boosted (safe — it runs
+ * at too-high priority, never too-low).
+ */
+static void ntsync_pi_recalc(struct ntsync_obj *obj)
+{
+	struct task_struct *owner = obj->u.mutex.owner_task;
+	struct ntsync_device *dev = obj->dev;
+	struct ntsync_pi_owner *po;
+	struct ntsync_q_entry *entry;
+	int highest_prio = MAX_PRIO;
+	int base_prio;
+	bool was_boosted, needs_boost;
+
+	if (!owner)
+		return;
+
+	ntsync_assert_held(obj);
+
+	/* Find highest-priority waiter across both wait lists */
+	list_for_each_entry(entry, &obj->any_waiters, node) {
+		if (entry->obj == obj && entry->q->task->prio < highest_prio)
+			highest_prio = entry->q->task->prio;
+	}
+	list_for_each_entry(entry, &obj->all_waiters, node) {
+		if (entry->obj == obj && entry->q->task->prio < highest_prio)
+			highest_prio = entry->q->task->prio;
+	}
+
+	raw_spin_lock(&dev->boost_lock);
+
+	po = find_pi_owner(dev, owner);
+
+	/* Compare against the ORIGINAL priority, not current (which may
+	 * already be boosted by this or another mutex). */
+	base_prio = po ? po->orig_normal_prio : owner->normal_prio;
+	needs_boost = (highest_prio < base_prio);
+	was_boosted = obj->u.mutex.pi_boosted;
+
+	if (needs_boost && !was_boosted) {
+		/* This object is newly contributing a boost */
+		if (!po) {
+			po = kzalloc(sizeof(*po), GFP_ATOMIC);
+			if (unlikely(!po))
+				goto out;
+			po->task = owner;
+			po->orig_attr = (struct sched_attr){
+				.size = sizeof(struct sched_attr),
+				.sched_policy = owner->policy,
+				.sched_priority = owner->rt_priority,
+				.sched_nice = PRIO_TO_NICE(owner->static_prio),
+			};
+			po->orig_normal_prio = owner->normal_prio;
+			po->boost_count = 0;
+			list_add(&po->node, &dev->boosted_owners);
+		}
+		po->boost_count++;
+		obj->u.mutex.pi_boosted = true;
+	}
+
+	if (needs_boost) {
+		/* Apply or raise the boost.  Never lower while other objects
+		 * are still boosting (safe conservative over-boost). */
+		if (highest_prio < owner->prio) {
+			struct sched_attr boost = {
+				.size = sizeof(struct sched_attr),
+				.sched_policy = SCHED_FIFO,
+				.sched_priority = MAX_RT_PRIO - 1 - highest_prio,
+			};
+			sched_setattr_nocheck(owner, &boost);
+		}
+	} else if (was_boosted) {
+		/* This object no longer contributes a boost */
+		obj->u.mutex.pi_boosted = false;
+		if (po) {
+			po->boost_count--;
+			if (po->boost_count <= 0) {
+				/* Last boost removed — restore original */
+				sched_setattr_nocheck(owner, &po->orig_attr);
+				list_del(&po->node);
+				kfree(po);
+			}
+			/* boost_count > 0: another mutex still boosting,
+			 * leave the conservative over-boost in place. */
+		}
+	}
+out:
+	raw_spin_unlock(&dev->boost_lock);
+}
