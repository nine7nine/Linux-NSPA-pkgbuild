+/* ============================================================
+ * NSPA patch 1010: NTSYNC_IOC_AGGREGATE_WAIT
+ *
+ * Heterogeneous wait over N ntsync objects + M file descriptors +
+ * optional absolute deadline.  Mirrors ntsync_wait_any's lifecycle
+ * (queue / already-signaled-check / sleep / unqueue) and adds
+ * fd-source registration via vfs_poll.
+ *
+ * NT semantics for object sources are inherited from the existing
+ * try_wake_any_* helpers (mutex acquired, auto-event reset, sem
+ * decremented on signal — same as WaitForMultipleObjects).  Channel
+ * object sources are notify-only; userspace consumes via CHANNEL_RECV2.
+ * Fd sources are pure Linux poll composition, no NT mapping.
+ *
+ * PREEMPT_RT discipline: all kmalloc/kfree happen outside raw locks.
+ * pi_work pool pre-allocated for any mutex sources, drained on exit;
+ * empty pool falls back to silent skip-boost (transient priority
+ * inversion, same as wait_any).  sched_setattr_nocheck is safe under
+ * raw_spinlock_t; wake_up_process likewise.
+ *
+ * Inherits wait_any's narrow signaled-vs-timeout race window between
+ * schedule-return and the unqueue list_del — same trade-off there
+ * applies here.
+ * ============================================================
+ */
+
+/* Per-fd-source tracking.  src_index preserves the user's source-array
+ * order so fired_index reflects user-supplied ordering. */
+struct ntsync_agg_fd {
+	struct file *file;
+	__u32 events;
+	__u32 fired_events;
+	__u32 src_index;
+};
+
+static int ntsync_aggregate_setup(struct ntsync_device *dev,
+				  const struct ntsync_aggregate_wait_args *args,
+				  struct ntsync_q **ret_q,
+				  struct ntsync_agg_fd **ret_fds,
+				  __u32 *ret_nb_obj, __u32 *ret_nb_fd)
+{
+	struct ntsync_aggregate_source srcs[NTSYNC_AGG_MAX];
+	struct ntsync_q *q;
+	struct ntsync_agg_fd *fds = NULL;
+	__u32 nb = args->nb_sources;
+	__u32 nb_obj = 0, nb_fd = 0;
+	__u32 obj_idx = 0, fd_idx = 0;
+	__u32 i, j;
+	int ret;
+
+	if (nb < 1 || nb > NTSYNC_AGG_MAX)
+		return -EINVAL;
+	if (args->flags & ~NTSYNC_AGG_FLAG_REALTIME)
+		return -EINVAL;
+	if (args->__pad)
+		return -EINVAL;
+
+	if (copy_from_user(srcs, u64_to_user_ptr(args->sources),
+			   nb * sizeof(srcs[0])))
+		return -EFAULT;
+
+	/* Validate types/__pad and count obj vs fd sources. */
+	for (i = 0; i < nb; i++) {
+		if (srcs[i].__pad)
+			return -EINVAL;
+		switch (srcs[i].type) {
+		case NTSYNC_AGG_OBJECT:
+			if (srcs[i].events)
+				return -EINVAL;
+			nb_obj++;
+			break;
+		case NTSYNC_AGG_FD:
+			nb_fd++;
+			break;
+		default:
+			return -EINVAL;
+		}
+	}
+
+	q = kmalloc(struct_size(q, entries, nb_obj), GFP_KERNEL);
+	if (!q)
+		return -ENOMEM;
+	q->task = current;
+	q->owner = args->owner;
+	atomic_set(&q->signaled, -1);
+	q->all = false;
+	q->ownerdead = false;
+	q->count = nb_obj;
+
+	if (nb_fd) {
+		fds = kmalloc_array(nb_fd, sizeof(*fds), GFP_KERNEL);
+		if (!fds) {
+			kfree(q);
+			return -ENOMEM;
+		}
+	}
+
+	/* Resolve every source.  entry->index / fds[k].src_index store
+	 * the original user-array index so fired_index is reported in
+	 * the user's source-array convention. */
+	for (i = 0; i < nb; i++) {
+		if (srcs[i].type == NTSYNC_AGG_OBJECT) {
+			struct ntsync_q_entry *entry = &q->entries[obj_idx];
+			struct ntsync_obj *obj = get_obj(dev, srcs[i].fd);
+
+			if (!obj) {
+				ret = -EBADF;
+				goto err;
+			}
+			entry->obj = obj;
+			entry->q = q;
+			entry->index = i;
+			INIT_LIST_HEAD(&entry->node);
+			obj_idx++;
+		} else {
+			struct file *file = fget(srcs[i].fd);
+
+			if (!file) {
+				ret = -EBADF;
+				goto err;
+			}
+			fds[fd_idx].file = file;
+			fds[fd_idx].events = srcs[i].events;
+			fds[fd_idx].fired_events = 0;
+			fds[fd_idx].src_index = i;
+			fd_idx++;
+		}
+	}
+
+	*ret_q = q;
+	*ret_fds = fds;
+	*ret_nb_obj = nb_obj;
+	*ret_nb_fd = nb_fd;
+	return 0;
+
+err:
+	for (j = 0; j < obj_idx; j++)
+		put_obj(q->entries[j].obj);
+	for (j = 0; j < fd_idx; j++)
+		fput(fds[j].file);
+	kfree(fds);
+	kfree(q);
+	return ret;
+}
+
+static int ntsync_aggregate_schedule(struct ntsync_q *q,
+				     struct ntsync_agg_fd *fds, __u32 nb_fd,
+				     const struct ntsync_aggregate_wait_args *args)
+{
+	ktime_t timeout = ns_to_ktime(args->timeout);
+	clockid_t clock = CLOCK_MONOTONIC;
+	struct poll_wqueues pwq;
+	ktime_t *timeout_ptr;
+	bool pwq_ready = false;
+	int ret = 0;
+	__u32 i;
+
+	timeout_ptr = (args->timeout == U64_MAX) ? NULL : &timeout;
+	if (args->flags & NTSYNC_AGG_FLAG_REALTIME)
+		clock = CLOCK_REALTIME;
+
+	/* Register a poll wait against each fd's wait queue once.
+	 * vfs_poll(file, &pwq.pt) appends a poll_table_entry per call;
+	 * poll_freewait drains the whole list on exit.  Same one-poll-
+	 * table-many-fds shape that fs/select.c::do_select uses. */
+	if (nb_fd) {
+		poll_initwait(&pwq);
+		pwq_ready = true;
+		for (i = 0; i < nb_fd; i++)
+			vfs_poll(fds[i].file, &pwq.pt);
+	}
+
+	do {
+		if (signal_pending(current)) {
+			ret = -ERESTARTSYS;
+			break;
+		}
+
+		set_current_state(TASK_INTERRUPTIBLE);
+
+		if (atomic_read(&q->signaled) != -1) {
+			ret = 0;
+			break;
+		}
+
+		for (i = 0; i < nb_fd; i++) {
+			__poll_t mask = vfs_poll(fds[i].file, NULL) &
+					(__poll_t)fds[i].events;
+
+			if (mask) {
+				int signaled = -1;
+
+				if (atomic_try_cmpxchg(&q->signaled, &signaled,
+						       fds[i].src_index))
+					fds[i].fired_events = mask;
+				ret = 0;
+				goto done;
+			}
+		}
+
+		ret = schedule_hrtimeout_range_clock(timeout_ptr, 0,
+						      HRTIMER_MODE_ABS, clock);
+	} while (ret < 0);
+
+done:
+	__set_current_state(TASK_RUNNING);
+
+	if (pwq_ready)
+		poll_freewait(&pwq);
+
+	return ret;
+}
+
+static int ntsync_aggregate_wait(struct ntsync_device *dev, void __user *argp)
+{
+	struct ntsync_aggregate_wait_args args;
+	struct ntsync_pi_work pi_work;
+	struct ntsync_q *q = NULL;
+	struct ntsync_agg_fd *fds = NULL;
+	__u32 nb_obj = 0, nb_fd = 0;
+	__u32 i, fired_events_out = 0;
+	int signaled;
+	bool all;
+	int ret;
+
+	if (copy_from_user(&args, argp, sizeof(args)))
+		return -EFAULT;
+
+	/* Drain pending event-PI boosts from a prior wake.  Symmetric
+	 * with WAIT_ANY/WAIT_ALL — entering a wait means the task is
+	 * done with whatever message(s) prompted the boost. */
+	drain_event_pi_boosts(dev, current);
+
+	ret = ntsync_aggregate_setup(dev, &args, &q, &fds, &nb_obj, &nb_fd);
+	if (ret < 0)
+		return ret;
+
+	ntsync_pi_work_init(&pi_work);
+
+	/* Queue ourselves on each obj's any_waiters.  Aggregate-waiters
+	 * share the WAIT_ANY waiter list, so the existing PI-propagation
+	 * paths (mutex pi_recalc, EVENT_SET_PI consume, channel SEND_PI
+	 * boost via try_wake_any_channel_notify) find us transparently. */
+	for (i = 0; i < nb_obj; i++) {
+		struct ntsync_q_entry *entry = &q->entries[i];
+		struct ntsync_obj *obj = entry->obj;
+
+		if (obj->type == NTSYNC_TYPE_MUTEX &&
+		    list_empty(&pi_work.new_po_pool))
+			ntsync_pi_work_prealloc(&pi_work);
+
+		all = ntsync_lock_obj(dev, obj);
+		ntsync_insert_waiter(entry, &obj->any_waiters);
+		if (obj->type == NTSYNC_TYPE_MUTEX)
+			ntsync_pi_recalc(obj, &pi_work);
+		ntsync_unlock_obj(dev, obj, all);
+	}
+
+	/* Already-signaled check before sleep.  Walks obj sources only;
+	 * fd readiness is checked inside the schedule loop. */
+	for (i = 0; i < nb_obj; i++) {
+		struct ntsync_obj *obj = q->entries[i].obj;
+
+		if (atomic_read(&q->signaled) != -1)
+			break;
+
+		if (obj->type == NTSYNC_TYPE_MUTEX &&
+		    list_empty(&pi_work.new_po_pool))
+			ntsync_pi_work_prealloc(&pi_work);
+
+		all = ntsync_lock_obj(dev, obj);
+		try_wake_any_obj(obj, &pi_work);
+		ntsync_unlock_obj(dev, obj, all);
+	}
+
+	ret = ntsync_aggregate_schedule(q, fds, nb_fd, &args);
+
+	/* Unqueue from each obj's any_waiters.  Always done — regardless
+	 * of fired/timeout/signal. */
+	signaled = atomic_read(&q->signaled);
+	for (i = 0; i < nb_obj; i++) {
+		struct ntsync_q_entry *entry = &q->entries[i];
+		struct ntsync_obj *obj = entry->obj;
+
+		if (obj->type == NTSYNC_TYPE_MUTEX &&
