 /*
+ * NSPA: Notify aggregate-waiters that a channel has pending requests.
+ *
+ * Called from ntsync_channel_send_pi after channel_pending_insert and
+ * from try_wake_any_obj on the channel-source path.  Mirrors
+ * try_wake_any_event but never mutates channel state — aggregate-waiters
+ * are notify-only on channels (they go on to call CHANNEL_RECV2 from
+ * userspace to actually consume the entry).
+ *
+ * PREEMPT_RT: wake_up_process is safe under raw_spinlock_t (uses rq->lock
+ * which is also raw, same as sched_setattr_nocheck used by pi_recalc).
+ */
+static void try_wake_any_channel_notify(struct ntsync_obj *ch)
+{
+	struct ntsync_q_entry *entry;
+
+	ntsync_assert_held(ch);
+	lockdep_assert(ch->type == NTSYNC_TYPE_CHANNEL);
+
+	list_for_each_entry(entry, &ch->any_waiters, node) {
+		struct ntsync_q *q = entry->q;
+		int signaled = -1;
+
+		if (!ch->u.channel.depth)
+			break;
+
+		if (atomic_try_cmpxchg(&q->signaled, &signaled, entry->index))
+			wake_up_process(q->task);
+	}
+}
