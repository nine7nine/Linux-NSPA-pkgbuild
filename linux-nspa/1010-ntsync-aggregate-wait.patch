 #define NTSYNC_IOC_CHANNEL_RECV2	_IOWR('N', 0x96, struct ntsync_channel_recv2_args)
 
+/*
+ * NSPA: Heterogeneous aggregate wait — patch 1010.
+ *
+ * Wait atomically on N ntsync objects + M file descriptors + optional
+ * absolute deadline.  Returns the index of the first source that fired,
+ * or NTSYNC_AGG_TIMEOUT on deadline expiry.
+ *
+ * For NTSYNC_AGG_OBJECT sources the waiter is registered on the existing
+ * obj->any_waiters list, so the existing PI-propagation paths
+ * (mutex pi_recalc, EVENT_SET_PI consume, channel SEND_PI boost) find
+ * aggregate-waiters without modification.
+ *
+ * For NTSYNC_AGG_FD sources the kernel registers a poll wait against
+ * the fd's wait queue (vfs_poll machinery).  No PI propagation for fd
+ * sources — fd readiness has no priority owner.
+ *
+ * Channel-typed object sources are notify-only: aggregate-waiters wake
+ * when the channel's pending depth becomes nonzero, but do NOT consume
+ * a queue entry.  Userspace then issues NTSYNC_IOC_CHANNEL_RECV2 to
+ * pop the entry.
+ *
+ * timeout is a CLOCK_MONOTONIC absolute nanosecond value, U64_MAX = no
+ * deadline; NTSYNC_AGG_FLAG_REALTIME switches to CLOCK_REALTIME.  This
+ * matches the semantics of NTSYNC_IOC_WAIT_ANY exactly.
+ *
+ * fired_index is the index in the user-supplied sources[] array of the
+ * source that fired.  fired_events carries the POLL* mask for fd
+ * sources; 0 for object sources.
+ *
+ * On deadline expiry, fired_index is set to NTSYNC_AGG_TIMEOUT and the
+ * ioctl returns -ETIMEDOUT.
+ *
+ * The owner field carries the Win32 mutex-owner identifier exactly as
+ * NTSYNC_IOC_WAIT_ANY uses it (re-entrant mutex acquisition).  Pass 0
+ * if no mutex sources are present.
+ *
+ * Primary motivating consumer: gamma-channel dispatcher waiting
+ * atomically on (channel, io_uring CQE eventfd).  See
+ * wine/nspa/docs/aggregate-wait-and-async-completion.md.
+ */
+struct ntsync_aggregate_source {
+	__u32 type;          /* NTSYNC_AGG_OBJECT | NTSYNC_AGG_FD */
+	__u32 events;        /* if FD: POLL* bits to watch; if OBJECT: must be 0 */
+	__u32 fd;            /* ntsync object fd, or unix file fd */
+	__u32 __pad;         /* reserved, must be 0 */
+};
+
+struct ntsync_aggregate_wait_args {
+	__u64 timeout;       /* IN: ABSTIME ns; U64_MAX = no deadline */
+	__u64 sources;       /* IN: user ptr to ntsync_aggregate_source[] */
+	__u32 nb_sources;    /* IN: 1..NTSYNC_AGG_MAX */
+	__u32 fired_index;   /* OUT: 0..nb-1 of firing source, or NTSYNC_AGG_TIMEOUT */
+	__u32 flags;         /* IN: NTSYNC_AGG_FLAG_REALTIME */
+	__u32 owner;         /* IN: Win32 mutex owner; 0 if none */
+	__u32 fired_events;  /* OUT: POLL* bits for FD source, 0 for OBJECT */
+	__u32 __pad;         /* reserved, must be 0 */
+};
+
+#define NTSYNC_AGG_OBJECT		0x1
+#define NTSYNC_AGG_FD			0x2
+
+#define NTSYNC_AGG_MAX			64
+
+#define NTSYNC_AGG_FLAG_REALTIME	0x1
+
+#define NTSYNC_AGG_TIMEOUT		0xFFFFFFFFu
+
+#define NTSYNC_IOC_AGGREGATE_WAIT	_IOWR('N', 0x97, struct ntsync_aggregate_wait_args)
+
 #endif
