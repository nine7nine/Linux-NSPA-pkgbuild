+static int __init ntsync_init(void)
+{
+	int ret;
+
+	ntsync_event_pi_cache = kmem_cache_create("ntsync_event_pi",
+						  sizeof(struct ntsync_event_pi),
+						  0, SLAB_HWCACHE_ALIGN, NULL);
+	if (!ntsync_event_pi_cache)
+		return -ENOMEM;
+
+	ntsync_channel_entry_cache = kmem_cache_create("ntsync_channel_entry",
+						       sizeof(struct ntsync_channel_entry),
+						       0, SLAB_HWCACHE_ALIGN, NULL);
+	if (!ntsync_channel_entry_cache) {
+		ret = -ENOMEM;
+		goto err_chan;
+	}
+
+	ntsync_pi_owner_cache = kmem_cache_create("ntsync_pi_owner",
+						  sizeof(struct ntsync_pi_owner),
+						  0, SLAB_HWCACHE_ALIGN, NULL);
+	if (!ntsync_pi_owner_cache) {
+		ret = -ENOMEM;
+		goto err_po;
+	}
+
+	ret = misc_register(&ntsync_misc);
+	if (ret)
+		goto err_misc;
+
+	return 0;
+
+err_misc:
+	kmem_cache_destroy(ntsync_pi_owner_cache);
+err_po:
+	kmem_cache_destroy(ntsync_channel_entry_cache);
+err_chan:
+	kmem_cache_destroy(ntsync_event_pi_cache);
+	return ret;
+}
+module_init(ntsync_init);
+
+static void __exit ntsync_exit(void)
+{
+	/* misc_deregister drains all open device fds; ntsync_free_obj runs
+	 * for every still-live object and returns its slab to its cache.
+	 * After deregister, no callers can reach the caches. */
+	misc_deregister(&ntsync_misc);
+	kmem_cache_destroy(ntsync_pi_owner_cache);
+	kmem_cache_destroy(ntsync_channel_entry_cache);
+	kmem_cache_destroy(ntsync_event_pi_cache);
+}
+module_exit(ntsync_exit);
 
