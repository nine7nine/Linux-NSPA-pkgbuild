+/*
+ * NSPA: register or replace the (tid -> token) mapping for this channel.
+ * Caller (wineserver) is the channel's controlling process; the kernel
+ * does not validate sender TIDs against registered ones — registration
+ * is purely a wineserver-driven plumbing convenience.
+ */
+static int ntsync_channel_register_thread(struct ntsync_obj *ch, void __user *argp)
+{
+	struct ntsync_channel_register_thread_args args;
+	struct ntsync_thread_reg *reg, *cur;
+	struct ntsync_thread_reg *victim = NULL;
+	struct hlist_node *tmp;
+	u32 bucket;
+
+	if (ch->type != NTSYNC_TYPE_CHANNEL)
+		return -EINVAL;
+	if (copy_from_user(&args, argp, sizeof(args)))
+		return -EFAULT;
+	if (args.tid == 0)
+		return -EINVAL;
+
+	reg = kzalloc(sizeof(*reg), GFP_KERNEL);
+	if (!reg)
+		return -ENOMEM;
+	reg->tid   = args.tid;
+	reg->token = args.token;
+	bucket = args.tid & 63;
+
+	obj_lock(ch);
+	hlist_for_each_entry_safe(cur, tmp, &ch->u.channel.thread_regs[bucket], hnode) {
+		if (cur->tid == args.tid) {
+			hlist_del(&cur->hnode);
+			/* Defer kfree past obj_unlock — slab on PREEMPT_RT
+			 * uses sleeping locks; cannot kfree under raw. */
+			victim = cur;
+			break;
+		}
+	}
+	hlist_add_head(&reg->hnode, &ch->u.channel.thread_regs[bucket]);
+	obj_unlock(ch);
+
+	kfree(victim);  /* NULL-safe */
+	return 0;
+}
+
+static int ntsync_channel_deregister_thread(struct ntsync_obj *ch, void __user *argp)
+{
+	struct ntsync_thread_reg *cur, *victim = NULL;
+	struct hlist_node *tmp;
+	u32 tid, bucket;
+
+	if (ch->type != NTSYNC_TYPE_CHANNEL)
+		return -EINVAL;
+	if (copy_from_user(&tid, argp, sizeof(tid)))
+		return -EFAULT;
+	bucket = tid & 63;
+
+	obj_lock(ch);
+	hlist_for_each_entry_safe(cur, tmp, &ch->u.channel.thread_regs[bucket], hnode) {
+		if (cur->tid == tid) {
+			hlist_del(&cur->hnode);
+			/* Defer kfree past obj_unlock (PREEMPT_RT). */
+			victim = cur;
+			break;
+		}
+	}
+	obj_unlock(ch);
+
+	kfree(victim);  /* NULL-safe */
+	return 0;
+}
