+/*
+ * NSPA: Apply an event PI boost to @target from a sender.
+ *
+ * PREEMPT_RT semantics:
+ *  - @new_ep is pre-allocated by caller with GFP_KERNEL (may sleep),
+ *    before any raw_spin_lock.  kzalloc under raw_spin_lock would
+ *    deadlock on RT because slab uses rt_spin_lock internally.
+ *  - sched_setattr_nocheck is safe under raw_spin_lock (it takes
+ *    rq->lock which is also raw).  Same pattern used by PI v2's
+ *    ntsync_pi_recalc.
+ *
+ * Boost stacking: multiple EVENT_SET_PI calls against the same target
+ * increment boost_count.  The boost stays applied (conservative over-
+ * boost is safe — runs at too-high prio, never too-low).  A single
+ * drain_event_pi_boosts clears all at once when target re-enters wait.
+ *
+ * Returns true if @new_ep was consumed (caller must NOT free).
+ */
+static bool apply_event_pi_boost(struct ntsync_device *dev,
+				 struct task_struct *target,
+				 u32 policy, u32 prio,
+				 struct ntsync_event_pi *new_ep)
+{
+	struct ntsync_event_pi *ep;
+	struct sched_attr boost;
+	int boost_prio_internal;
+	bool consumed = false;
+
+	/* Convert sender's rt_priority (1..99) to kernel's internal
+	 * prio-value (lower number = higher priority).  Matches the
+	 * conversion used by ntsync_pi_recalc. */
+	boost_prio_internal = MAX_RT_PRIO - 1 - prio;
+
+	raw_spin_lock(&dev->boost_lock);
+
+	ep = find_event_pi(dev, target);
+	if (!ep) {
+		/* First boost against this target — need tracking entry */
+		if (unlikely(!new_ep))
+			goto out;
+		get_task_struct(target); /* entry holds its own ref */
+		new_ep->task = target;
+		new_ep->orig_attr = (struct sched_attr){
+			.size = sizeof(struct sched_attr),
+			.sched_policy = target->policy,
+			.sched_priority = target->rt_priority,
+			.sched_nice = PRIO_TO_NICE(target->static_prio),
+		};
+		new_ep->orig_normal_prio = target->normal_prio;
+		new_ep->boost_count = 0;
+		list_add(&new_ep->node, &dev->event_pi_tasks);
+		ep = new_ep;
+		consumed = true;
+	}
+	ep->boost_count++;
+
+	/* Apply the boost only if it's genuinely higher than current.
+	 * Never lower (safe conservative over-boost if another mutex
+	 * or event is already boosting this task). */
+	if (boost_prio_internal < target->prio) {
+		boost = (struct sched_attr){
+			.size = sizeof(struct sched_attr),
+			.sched_policy = policy,
+			.sched_priority = prio,
+		};
+		sched_setattr_nocheck(target, &boost);
+	}
+
+out:
+	raw_spin_unlock(&dev->boost_lock);
+	return consumed;
+}
