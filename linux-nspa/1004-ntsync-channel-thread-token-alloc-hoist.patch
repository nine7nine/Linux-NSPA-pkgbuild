+/*
+ * NSPA: RT-safe context for PI-boost adjustments.
+ *
+ * On PREEMPT_RT, slab alloc/free takes a sleeping lock (local_lock_t is
+ * spinlock_t on RT, and SLUB's per-CPU fast path calls migrate_disable
+ * + spin_lock).  kzalloc()/kfree() therefore CANNOT be called under
+ * raw_spinlock_t — neither obj->lock nor dev->boost_lock.
+ *
+ * Each ioctl entry that may invoke pi_recalc / pi_drop declares one of
+ * these on stack, pre-allocates new_po entries BEFORE taking any raw
+ * lock, and calls _finish() AFTER releasing all raw locks.
+ *
+ * Lifecycle of a pi_owner via this struct:
+ *   - kzalloc -> list_add to new_po_pool                   (caller, no lock)
+ *   - consumed: list_del from pool, list_add to dev list   (pi_recalc, raw)
+ *   - removed: list_move from dev list to to_free_list     (pi_recalc/_drop, raw)
+ *   - kfree from new_po_pool + to_free_list                (caller, no lock)
+ *
+ * Empty pool is a non-fatal fallback: pi_recalc skips the boost,
+ * matching the prior GFP_ATOMIC behaviour (transient priority
+ * inversion until the next op).
+ */
+struct ntsync_pi_work {
+	struct list_head new_po_pool;     /* pre-allocated; consumed on demand */
+	struct list_head to_free_list;    /* removed entries to free post-unlock */
+};
+
+static inline void ntsync_pi_work_init(struct ntsync_pi_work *w)
+{
+	INIT_LIST_HEAD(&w->new_po_pool);
+	INIT_LIST_HEAD(&w->to_free_list);
+}
+
+/*
+ * Pre-allocate one pi_owner entry into the pool.  Allocation failure
+ * is non-fatal — pi_recalc skips the boost when the pool is empty.
+ * Call OUTSIDE any raw_spinlock_t.
+ */
+static inline void ntsync_pi_work_prealloc(struct ntsync_pi_work *w)
+{
+	struct ntsync_pi_owner *po = kzalloc(sizeof(*po), GFP_KERNEL);
+
+	if (po) {
+		INIT_LIST_HEAD(&po->node);
+		list_add(&po->node, &w->new_po_pool);
+	}
+}
+
+/*
+ * Consume one pre-allocated entry from the pool.  Caller is under the
+ * raw_spinlock_t that protects dev->boosted_owners.  Returns NULL if
+ * the pool is empty (caller falls back to skipping the boost).
+ */
+static struct ntsync_pi_owner *
+ntsync_pi_work_take_new(struct ntsync_pi_work *w)
+{
+	struct ntsync_pi_owner *po;
+
+	if (list_empty(&w->new_po_pool))
+		return NULL;
+	po = list_first_entry(&w->new_po_pool, struct ntsync_pi_owner, node);
+	list_del(&po->node);
+	return po;
+}
+
+/*
+ * Free unused pre-allocated entries and entries removed from
+ * dev->boosted_owners by pi_drop/pi_recalc.  MUST be called outside
+ * any raw_spinlock_t.
+ */
+static inline void ntsync_pi_work_finish(struct ntsync_pi_work *w)
+{
+	struct ntsync_pi_owner *po, *tmp;
+
+	list_for_each_entry_safe(po, tmp, &w->new_po_pool, node) {
+		list_del(&po->node);
+		kfree(po);
+	}
+	list_for_each_entry_safe(po, tmp, &w->to_free_list, node) {
+		list_del(&po->node);
+		kfree(po);
+	}
+}
