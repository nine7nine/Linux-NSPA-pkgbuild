+/*
+ * REPLY: locate the dispatched entry by id, mark replied, wake sender.
+ * Drains the recv'er's PI boost (we're the recv'er; we just finished
+ * handling).
+ */
+static int ntsync_channel_reply(struct ntsync_obj *ch, void __user *argp)
+{
+	__u64 entry_id;
+	struct ntsync_channel_entry *e = NULL, *cur;
+
+	if (ch->type != NTSYNC_TYPE_CHANNEL)
+		return -EINVAL;
+	if (copy_from_user(&entry_id, argp, sizeof(entry_id)))
+		return -EFAULT;
+
+	obj_lock(ch);
+	list_for_each_entry(cur, &ch->u.channel.dispatched, list) {
+		if (cur->id == entry_id) {
+			e = cur;
+			break;
+		}
+	}
+	if (!e || e->replied) {
+		obj_unlock(ch);
+		return -ENOENT;
+	}
+	e->replied = true;
+	obj_unlock(ch);
+
+	wake_up_all(&e->wq);
+
+	/* Drain our boost — handler is done. */
+	drain_event_pi_boosts(ch->dev, current);
