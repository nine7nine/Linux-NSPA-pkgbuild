+static int ntsync_create_channel(struct ntsync_device *dev, void __user *argp)
+{
+	struct ntsync_channel_create_args args;
+	struct ntsync_obj *ch;
+	int fd;
+
+	if (copy_from_user(&args, argp, sizeof(args)))
+		return -EFAULT;
+	if (!args.max_depth || args.max_depth > NTSYNC_CHANNEL_MAX_DEPTH)
+		return -EINVAL;
+
+	ch = ntsync_alloc_obj(dev, NTSYNC_TYPE_CHANNEL);
+	if (!ch)
+		return -ENOMEM;
+	ch->u.channel.pending    = RB_ROOT;
+	INIT_LIST_HEAD(&ch->u.channel.dispatched);
+	atomic64_set(&ch->u.channel.next_id, 0);
+	atomic64_set(&ch->u.channel.next_seq, 0);
+	ch->u.channel.depth      = 0;
+	ch->u.channel.max_depth  = args.max_depth;
+	init_waitqueue_head(&ch->u.channel.recv_wq);
+	{
+		int i;
+		for (i = 0; i < 64; i++)
+			INIT_HLIST_HEAD(&ch->u.channel.thread_regs[i]);
+	}
+
+	fd = ntsync_obj_get_fd(ch);
+	if (fd < 0)
+		ntsync_free_obj(ch);
+	return fd;
+}
