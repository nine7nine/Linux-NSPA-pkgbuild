+static struct ntsync_event_pi *find_event_pi(struct ntsync_device *dev,
+					     struct task_struct *task)
+{
+	struct ntsync_event_pi *ep;
+
+	list_for_each_entry(ep, &dev->event_pi_tasks, node) {
