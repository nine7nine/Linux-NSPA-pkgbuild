+/*
+ * NSPA: Drain any pending event-PI boosts for @task.
+ *
+ * Called at the top of ntsync_wait_any/wait_all: re-entering a wait
+ * implies the task is done processing any messages that triggered
+ * boosts.  Restores original scheduling attrs and frees the entry.
+ *
+ * A single call drains ALL accumulated boosts in one restore, which
+ * matches the semantic intent ("I'm done with the batch").
+ */
+static void drain_event_pi_boosts(struct ntsync_device *dev,
+				  struct task_struct *task)
+{
+	struct ntsync_event_pi *ep;
+	struct sched_attr restore;
+	struct task_struct *ref_to_put = NULL;
+
+	raw_spin_lock(&dev->boost_lock);
+	ep = find_event_pi(dev, task);
+	if (ep) {
+		restore = ep->orig_attr;
+		list_del(&ep->node);
+		ref_to_put = ep->task;
+		/* Apply restore while still holding boost_lock to serialize
+		 * against any concurrent apply_event_pi_boost that might see
+		 * the list briefly empty.  Same lock, so new boost against
+		 * this task cannot race with our restore here. */
+		sched_setattr_nocheck(task, &restore);
+	}
+	raw_spin_unlock(&dev->boost_lock);
+
+	if (ref_to_put) {
+		put_task_struct(ref_to_put);
+		kfree(ep);
 	}
 }
 
