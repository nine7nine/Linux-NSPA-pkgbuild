+/*
+ * NSPA: Kernel-mediated request/reply channel.
+ *
+ * A channel is a bounded mailbox with a kernel-side priority queue.
+ * Senders post requests with a priority and block until a reply arrives.
+ * A receiver pops the highest-priority pending request, dispatches it
+ * in user space, and signals completion via REPLY.  Priority inheritance
+ * is atomic: SEND boosts the blocked receiver to the sender's priority,
+ * and RECV further auto-boosts the receiver to the popped request's
+ * priority for the duration of the handler.  Drain happens at REPLY and
+ * at the next RECV (mirroring EVENT_SET_PI's drain-on-wait pattern).
+ *
+ * Replaces the user-space futex + manual sched_setscheduler request_shm
+ * IPC used by Wine-NSPA's wineserver fast path.  One channel per
+ * wineserver-client process.  Payload offsets are opaque to the kernel —
+ * conventionally indices into a per-process shared-memory region the
+ * client and server both map.
+ *
+ * State machine per entry:
+ *   PENDING   — in the priority tree, sender blocked on entry->wq
+ *   DISPATCHED — popped by RECV, sender still blocked
+ *   REPLIED   — REPLY signalled; sender woken; entry freed by sender
+ */
+struct ntsync_channel_create_args {
+	__u32 max_depth;     /* bounded queue size, 1..NTSYNC_CHANNEL_MAX_DEPTH */
+	__u32 __pad;
+};
+
+struct ntsync_channel_send_args {
+	__u32 policy;        /* SCHED_FIFO/RR; 0 = no PI */
+	__u32 prio;          /* sched_priority 1..99; 0 = no PI */
+	__u64 payload_off;   /* opaque cookie copied to RECV */
+	__u64 reply_off;     /* opaque cookie copied to RECV */
+};
+
+struct ntsync_channel_recv_args {
+	__u64 entry_id;      /* OUT: pass to REPLY */
+	__u64 payload_off;   /* OUT: from sender */
+	__u64 reply_off;     /* OUT: from sender */
+	__u32 sender_tid;    /* OUT: linux TID for diagnostics */
+	__u32 prio;          /* OUT: priority of popped entry */
+};
+
+/*
+ * NSPA: thread-token pass-through.  Wineserver registers per-thread
+ * tokens via REGISTER_THREAD; the kernel stamps the token onto each
+ * channel entry at SEND_PI and returns it via RECV2.  Eliminates the
+ * userspace get_thread_from_id() lookup from the dispatcher hot loop.
+ */
+struct ntsync_channel_register_thread_args {
+	__u32 tid;           /* IN: linux task PID (tgid-namespaced) */
+	__u32 __pad;
+	__u64 token;         /* IN: opaque cookie returned at RECV2 */
+};
+
+struct ntsync_channel_recv2_args {
+	__u64 entry_id;      /* OUT: pass to REPLY */
+	__u64 payload_off;   /* OUT: from sender */
+	__u64 reply_off;     /* OUT: from sender */
+	__u32 sender_tid;    /* OUT: linux TID for diagnostics */
+	__u32 prio;          /* OUT: priority of popped entry */
+	__u64 thread_token;  /* OUT: registered token (0 if unregistered) */
+};
+
+#define NTSYNC_CHANNEL_MAX_DEPTH	1024
+
+#define NTSYNC_IOC_CREATE_CHANNEL	_IOWR('N', 0x90, struct ntsync_channel_create_args)
+#define NTSYNC_IOC_CHANNEL_SEND_PI	_IOWR('N', 0x91, struct ntsync_channel_send_args)
+#define NTSYNC_IOC_CHANNEL_RECV		_IOWR('N', 0x92, struct ntsync_channel_recv_args)
+#define NTSYNC_IOC_CHANNEL_REPLY	_IOW ('N', 0x93, __u64)
+#define NTSYNC_IOC_CHANNEL_REGISTER_THREAD \
