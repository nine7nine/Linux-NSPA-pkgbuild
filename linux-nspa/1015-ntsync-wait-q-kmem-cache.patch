 /*
+ * NSPA 1015: allocate a struct ntsync_q with `total_count` flexible-array
+ * entries.  Routes to ntsync_wait_q_cache when total_count fits the cache
+ * slot (≤ NTSYNC_Q_CACHE_MAX_ENTRIES); otherwise falls back to kmalloc.
+ *
+ * Caller must subsequently initialize every field.  q->from_cache is set
+ * here so ntsync_free_q can route correctly even for the early-error path
+ * where partial entries[] population has not yet happened (the only
+ * fields this allocator touches are from_cache; the rest are caller's
+ * responsibility, identical to the prior kmalloc-then-init pattern).
+ *
+ * GFP_KERNEL is preserved.  Both kmem_cache_alloc and kmalloc are
+ * sleep-prone (they may reclaim) and must not be called under raw
+ * spinlocks — the 1006 alloc-hoist invariant.  Every caller of
+ * ntsync_alloc_q is at function entry, before any obj_lock /
+ * wait_all_lock acquisition.
+ */
+static struct ntsync_q *ntsync_alloc_q(__u32 total_count)
+{
+	struct ntsync_q *q;
+
+	if (total_count <= NTSYNC_Q_CACHE_MAX_ENTRIES) {
+		q = kmem_cache_alloc(ntsync_wait_q_cache, GFP_KERNEL);
+		if (q)
+			q->from_cache = true;
+	} else {
+		q = kmalloc_flex(*q, entries, total_count);
+		if (q)
+			q->from_cache = false;
+	}
+	return q;
+}
+
+/*
+ * NSPA 1015: free a struct ntsync_q allocated by ntsync_alloc_q.
+ *
+ * NULL-safe by design (early return) — kmem_cache_free is NOT NULL-safe
+ * under SLAB_FREELIST_HARDENED (1014a lesson; see kernel mm/slub.c
+ * cache_from_obj derefing virt_to_cache(NULL) → vmemmap[0]+8 GP-fault).
+ * The 1014a fix ships explicit `if (ptr)` guards at every direct
+ * kmem_cache_free site; this wrapper centralizes the same guarantee for
+ * the WAIT_* / AGGREGATE_WAIT hot path so call-site audit stays trivial.
+ *
+ * RT discipline: every call site is after the per-iteration unqueue
+ * loop and ntsync_pi_work_finish — i.e., after every obj_lock,
+ * wait_all_lock, and pi_work allocation has been released/drained.
+ */
+static void ntsync_free_q(struct ntsync_q *q)
+{
+	if (!q)
+		return;
+	if (q->from_cache)
+		kmem_cache_free(ntsync_wait_q_cache, q);
+	else
+		kfree(q);
+}
